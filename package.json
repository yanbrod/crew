{
  "name": "@ianbrode/crew",
  "version": "0.1.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Declarative runner for multi-repo local dev environments — compose without containers",
  "keywords": [
    "cli",
    "multirepo",
    "polyrepo",
    "dev",
    "devtool",
    "orchestrator",
    "runner",
    "compose",
    "monorepo-alternative"
  ],
  "homepage": "https://github.com/yanbrod/crew#readme",
  "bugs": "https://github.com/yanbrod/crew/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yanbrod/crew.git"
  },
  "license": "MIT",
  "author": "Ian Brodetskii <ianbrode@gmail.com>",
  "type": "module",
  "bin": {
    "crew": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.4.0",
    "js-yaml": "^4.1.0",
    "tree-kill": "^1.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "memfs": "^4.9.3",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
